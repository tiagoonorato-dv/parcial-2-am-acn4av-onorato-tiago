<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_app">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- BIENVENIDA -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/welcome_title"
                android:textColor="@color/pet_primary"
                android:textSize="28sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="24dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Perfil"
                android:textColor="@color/white"
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mascotas registradas:"
                android:textColor="@color/text_secondary"
                android:textSize="16sp"
                android:layout_marginBottom="12dp"/>


            <!-- PERFIL PROFESIONAL -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/card_bg"
                android:orientation="horizontal"
                android:padding="16dp"
                android:elevation="4dp">

                <ImageView
                    android:layout_width="90dp"
                    android:layout_height="90dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/imagen"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="16dp"
                    android:layout_gravity="center">

                    <TextView
                        android:id="@+id/tvPetName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rocco"
                        android:textColor="@color/white"
                        android:textSize="22sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvPetBreed"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Golden Retriever"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp"/>

                </LinearLayout>
            </LinearLayout>


            <!-- MODIFICAR PERFIL -->
            <Button
                android:id="@+id/btnEditProfile"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Editar"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:textColor="@color/pet_primary"
                android:textSize="12sp"/>

            <!-- SECCIÓN VACUNAS -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/section_vaccines"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="18sp"
                android:layout_marginTop="32dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <EditText
                    android:id="@+id/editVaccine"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="@string/hint_vaccine"
                    android:textColor="@color/white"
                    android:textColorHint="@color/text_secondary"
                    android:backgroundTint="@color/pet_primary"/>

                <Button
                    android:id="@+id/btnAddVaccine"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/btn_add_vaccine"
                    android:backgroundTint="@color/pet_primary"
                    android:textColor="@color/white"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/containerVaccines"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="8dp"/>

            <!-- SECCIÓN AGREGAR CONSULTA -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/section_appointments"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="18sp"
                android:layout_marginTop="32dp"/>

            <LinearLayout
                android:id="@+id/containerAppointments"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/card_bg"
                android:padding="16dp"
                android:layout_marginTop="8dp">

                <EditText
                    android:id="@+id/editAppointment"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Día y hora (Ej: Martes 16:00)"
                    android:textColor="@color/white"
                    android:textColorHint="@color/text_secondary"
                    android:backgroundTint="@color/pet_primary"
                    android:layout_marginBottom="16dp"/>

                <Button
                    android:id="@+id/btnSchedule"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="AGENDAR TURNO"
                    android:backgroundTint="@color/pet_primary"
                    android:textColor="@color/white"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>