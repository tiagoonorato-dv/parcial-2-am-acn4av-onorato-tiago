<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/section_appointments"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <EditText
            android:id="@+id/etAppointmentDetails"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/appointment_hint"
            android:textColor="@color/white"
            android:textColorHint="@color/text_secondary"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnScheduleAppointment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_schedule"
            android:backgroundTint="@color/pet_primary"
            android:layout_marginBottom="24dp" />

        <LinearLayout
            android:id="@+id/containerAppointments"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/card_bg"
            android:padding="16dp"
            android:elevation="2dp" />

    </LinearLayout>
</ScrollView>