<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvTitleEdit"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Editar Perfil"
        android:textColor="@color/white"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <EditText
        android:id="@+id/etEditName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Nombre de la mascota"
        android:textColor="@color/white"
        android:textColorHint="#888888"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitleEdit" />

    <EditText
        android:id="@+id/etEditBreed"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Raza de la mascota"
        android:textColor="@color/white"
        android:textColorHint="#888888"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/etEditName" />

    <Button
        android:id="@+id/btnSaveProfile"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="GUARDAR CAMBIOS"
        android:backgroundTint="#4CAF50"
        android:textColor="@color/white"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/etEditBreed" />

</androidx.constraintlayout.widget.ConstraintLayout>